# ═══ AXOps Environment Variables ═══
# Copy to .env for local dev. On Netlify, set in Site Settings > Environment Variables.

# GitHub (required)
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_ORG=your-github-org

# GitHub App (optional — 15K req/hr instead of 5K)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Jira (required for ticket integration)
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_TOKEN=your_jira_api_token
JIRA_PROJECT=PROJ

# AI (required for AI features)
ANTHROPIC_API_KEY=sk-ant-your-key

# Teams (optional)
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Security scanning (optional)
BLACKDUCK_URL=https://your-blackduck.com
BLACKDUCK_TOKEN=your_token
